# Required for /api/chat rate limiting.
# Sign up: https://console.upstash.com/redis (Free tier, pick the region nearest you)
# Create a Redis DB → "REST API" tab → copy URL + token below
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local-dev / CI bypass for the rate limiter (skips Upstash calls entirely).
# REFUSES TO START if NODE_ENV=production. Leave unset locally; CI sets RATE_LIMIT_BYPASS=1.
# RATE_LIMIT_BYPASS=

# ── AI chat (server-only — NEVER prefix with NEXT_PUBLIC_) ──────────────────────
# The chat works with ANY ONE of these keys. With none set, it gracefully replies
# with a "book a call" message. Add both for redundancy (Groq primary, Gemini fallback).
#
# Groq (primary — fast, free, no training on data): https://console.groq.com/keys
GROQ_API_KEY=
# Google Gemini (fallback — free tier): https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
#
# Optional knobs (sensible defaults shown):
# AI_PROVIDERS=groq,google      # ordered fallback chain; static reply is always last
# CHAT_ENABLED=1                # set to 0 to instantly disable the AI (kill-switch)
# CHAT_DAILY_CAP=500            # global per-day request ceiling (cost circuit-breaker)
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_MODEL=gemini-2.5-flash
